<Window x:Class="WarframeRelicOverlay.Presentation.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WarframeRelicOverlay.Presentation"
        Title="Relic Overlay"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="Manual"
        WindowStartupLocation="Manual"
        Width="0" Height="0">
    <!-- Position/size are driven entirely from code via SetPhysicalBounds
         (raw screen pixels). No Width/Height bindings: WPF's per-monitor
         DIP conversion was unreliable across mixed-DPI monitors. -->

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!-- Price label base style -->
        <Style x:Key="PriceLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="#FFFFD700" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="6"
                                      ShadowDepth="1"
                                      Opacity="0.9" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUntradeable}" Value="True">
                    <Setter Property="Foreground" Value="#FF999999" />
                    <Setter Property="FontSize" Value="14" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFailed}" Value="True">
                    <Setter Property="Foreground" Value="#FFFF6666" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Close button — the only interactive control on the overlay.
             Per-pixel hit-testing in code-behind (WM_NCHITTEST) keeps every
             other pixel click-through to the game. -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Foreground" Value="#DDFFFFFF" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="4"
                                Background="#CC1A1A2E"
                                BorderBrush="#33FFFFFF"
                                BorderThickness="1">
                            <TextBlock Text="&#x2715;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#EEC0392B" />
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#66FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- All content visibility controlled here — window itself is always "visible"
         but fully transparent, so toggling this Grid avoids window show/hide flicker. -->
    <Grid Visibility="{Binding IsOverlayVisible, Converter={StaticResource BoolToVisibility}}" 
          >

        <!-- ═══ Status indicator + close button — top center ═══ -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,12,0,0">
        <Border Padding="14,6"
                CornerRadius="4"
                VerticalAlignment="Center"
                Background="#CC1A1A2E"
                BorderBrush="#33FFFFFF"
                BorderThickness="1"
                Visibility="{Binding IsStatusVisible, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">

                <!-- Pulsing indicator dot -->
                <Ellipse Width="8" Height="8"
                         Fill="#FF44DD88"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoadingVisible}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="PulseStoryboard">
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="Opacity"
                                                    From="1.0" To="0.3"
                                                    Duration="0:0:0.6"
                                                    AutoReverse="True" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="PulseStoryboard" />
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <TextBlock Text="{Binding StatusText}"
                           Foreground="#DDFFFFFF"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

            <!-- Close button — quits the overlay app without Task Manager. -->
            <Button x:Name="CloseButton"
                    Style="{StaticResource CloseButtonStyle}"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    ToolTip="Close overlay"
                    Click="OnCloseClicked" />
        </StackPanel>

        <!-- ═══ Loading spinner — center of window ═══ -->
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="40" Height="40"
              Visibility="{Binding IsLoadingVisible, Converter={StaticResource BoolToVisibility}}">
            <Ellipse Stroke="#33FFFFFF"
                     StrokeThickness="3"
                     Fill="Transparent" />
            <Ellipse Stroke="#FFFFD700"
                     StrokeThickness="3"
                     Fill="Transparent"
                     StrokeDashArray="2 6"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <RotateTransform x:Name="SpinnerRotation" />
                </Ellipse.RenderTransform>
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation
                                    Storyboard.TargetName="SpinnerRotation"
                                    Storyboard.TargetProperty="Angle"
                                    From="0" To="360"
                                    Duration="0:0:1.2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
        </Grid>

        <!-- ═══ Price labels — positioned over detected reward cards ═══ -->
        <ItemsControl ItemsSource="{Binding PriceLabels}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type local:PriceLabel}">
                    <Border Background="#CC1A1A2E"
                            CornerRadius="4"
                            Padding="12,5"
                            BorderBrush="#33FFFFFF"
                            BorderThickness="1"
                            MinWidth="60"
                            HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Text}"
                                   Style="{StaticResource PriceLabelStyle}" />
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>
</Window>
